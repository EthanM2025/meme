# Doubao (Volcengine) speech-recognition credentials.
# Register at https://www.volcengine.com/, enable the Speech service,
# and create an API key under the "Streaming ASR Big Model 2.0" SKU.
#
# Copy this file to `.env` and fill in your own values.

DOUBAO_API_KEY=
DOUBAO_APP_ID=

# Volcengine resource IDs for the two ASR paths we use.
# File-based (fallback) and streaming. The defaults below match Volcengine's
# current naming as of 2026 — change only if Volcengine renames the SKU.
DOUBAO_RESOURCE_ID=volc.seedasr.auc
DOUBAO_STREAMING_RESOURCE_ID=volc.seedasr.sauc.duration
DOUBAO_STREAMING_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async
